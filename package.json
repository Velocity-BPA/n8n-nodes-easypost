{
  "name": "n8n-nodes-easypost",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for EasyPost shipping API providing 13 resources and 50+ operations for multi-carrier shipping, label generation, tracking, and address verification.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-easypost.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-easypost#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-easypost/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "easypost",
    "shipping",
    "usps",
    "ups",
    "fedex",
    "dhl",
    "labels",
    "tracking",
    "rates",
    "address-verification",
    "e-commerce",
    "fulfillment",
    "logistics"
  ],
  "main": "dist/nodes/EasyPost/EasyPost.node.js",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/EasyPostApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/EasyPost/EasyPost.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.27.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
